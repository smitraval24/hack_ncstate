{
    "containerDefinitions": [
        {
            "name": "mock-api",
            "image": "885049747266.dkr.ecr.us-east-1.amazonaws.com/mock-api:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 5001,
                    "hostPort": 5001,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:5001/health', timeout=3).read()\" || exit 1"
                ],
                "interval": 10,
                "timeout": 3,
                "retries": 2,
                "startPeriod": 5
            },
            "environment": [
                { "name": "API_FAULT_MODE", "value": "latency,error" }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/cream-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "mock-api"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "mock-api-task",
    "taskRoleArn": "arn:aws:iam::885049747266:role/cream-task-role",
    "executionRoleArn": "arn:aws:iam::885049747266:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}

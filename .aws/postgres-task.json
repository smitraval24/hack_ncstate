{
    "containerDefinitions": [
        {
            "name": "postgres",
            "image": "885049747266.dkr.ecr.us-east-1.amazonaws.com/hack-postgres:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 5432,
                    "hostPort": 5432,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "POSTGRES_USER", "value": "hello" },
                { "name": "POSTGRES_PASSWORD", "value": "password" },
                { "name": "POSTGRES_DB", "value": "hello" }
            ],
            "healthCheck": {
                "command": ["CMD-SHELL", "pg_isready -U hello"],
                "interval": 5,
                "timeout": 3,
                "retries": 2,
                "startPeriod": 5
            },
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/cream-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "postgres"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "postgres-task",
    "taskRoleArn": "arn:aws:iam::885049747266:role/cream-task-role",
    "executionRoleArn": "arn:aws:iam::885049747266:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}

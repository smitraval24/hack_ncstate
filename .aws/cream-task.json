{
    "containerDefinitions": [
        {
            "name": "cream-container",
            "image": "885049747266.dkr.ecr.us-east-1.amazonaws.com/creamandonion@sha256:f244a23eda1fd19590cbae6a13393d9d19d444e720cf9adab6fd2c53f8e077eb",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "cream-container-8000-tcp",
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:8000/health || exit 1"
                ],
                "interval": 10,
                "timeout": 3,
                "retries": 2,
                "startPeriod": 5
            },
            "environment": [
                { "name": "POSTGRES_HOST", "value": "postgres.cream.local" },
                { "name": "POSTGRES_PORT", "value": "5432" },
                { "name": "POSTGRES_USER", "value": "hello" },
                { "name": "POSTGRES_PASSWORD", "value": "password" },
                { "name": "POSTGRES_DB", "value": "hello" },
                { "name": "MOCK_API_BASE_URL", "value": "http://mock-api.cream.local:5001" },
                { "name": "CLOUDWATCH_ENABLED", "value": "true" },
                { "name": "AWS_REGION", "value": "us-east-1" },
                { "name": "CLOUDWATCH_LOG_GROUPS", "value": "/aws/lambda/FaultRouter" },
                { "name": "CLOUDWATCH_ONLY_FAULT_CODES", "value": "true" },
                { "name": "CLOUDWATCH_FAULT_CODES", "value": "FAULT_SQL_INJECTION_TEST,FAULT_EXTERNAL_API_LATENCY,FAULT_DB_TIMEOUT" },
                { "name": "CLOUDWATCH_LOOKBACK_MINUTES", "value": "240" },
                { "name": "CLOUDWATCH_LIMIT_PER_GROUP", "value": "200" },
                { "name": "CLOUDWATCH_FILTER_PATTERN", "value": "" },
                { "name": "NODE_ENV", "value": "production" },
                { "name": "PYTHON_VERSION", "value": "3.14.2" }
            ],
            "dependsOn": [],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/cream-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "cream-task",
    "taskRoleArn": "arn:aws:iam::885049747266:role/cream-task-role",
    "executionRoleArn": "arn:aws:iam::885049747266:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}
